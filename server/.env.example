PORT=3001
MONGODB_URI=mongodb://localhost:27017/household-copilot
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# File storage
UPLOAD_DIR=./uploads

# Gmail SMTP (App Password method)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# App URL (used in email links)
APP_URL=http://localhost:5173

# Web Push (browser push notifications). Generate a key pair once with:
#   npx web-push generate-vapid-keys
# Leave blank to disable push (email + in-app notifications still work).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Google Places API — location autocomplete and phone lookup in calendar events
# Enable "Places API" in Google Cloud Console and restrict the key to your server IP
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Vapi — AI phone calling (calendar appointment cancellations/reschedules)
# 1. Sign up at https://vapi.ai and get your API key from the dashboard
# 2. Add your Anthropic API key in Vapi dashboard → Providers so the voice agent can use Claude
# 3. Buy a phone number in Vapi dashboard → Phone Numbers, then paste its ID below
VAPI_API_KEY=your-vapi-api-key
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id
