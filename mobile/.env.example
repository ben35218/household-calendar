# Override the API base URL for this device/session. Required when testing on a
# physical device (the default localhost only works in a simulator). Use your
# machine's LAN IP and the server port, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.20:3001
# The API server must allowlist requests; native apps send no Origin so they are
# allowed through CORS automatically.
EXPO_PUBLIC_API_URL=

# RevenueCat iOS public SDK key. Without it, dev sessions show "Purchases
# coming soon" on the Plan screen (isPurchasesConfigured() is false). It's a
# public key — same value as eas.json preview/production.
EXPO_PUBLIC_RC_IOS_KEY=
